# Postgres connection string (Railway's Postgres plugin provides this)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# From the Twilio Console (Account SID + Auth Token)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Long random string you choose — protects the /admin API. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=change-me-to-a-long-random-string

# The public HTTPS URL this app is deployed at, no trailing slash.
# Used both to build the Dial action callback URL and to validate Twilio's
# request signatures, so it must exactly match what Twilio actually called.
PUBLIC_BASE_URL=https://your-app.up.railway.app

# Optional tuning (defaults shown)
SMS_COOLDOWN_MINUTES=30
DEFAULT_DIAL_TIMEOUT_SECONDS=20

NODE_ENV=production
