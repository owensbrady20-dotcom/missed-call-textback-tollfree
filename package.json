{
  "name": "missed-call-textback-tollfree",
  "version": "1.0.0",
  "description": "Missed-call auto text-back service, built around a Twilio toll-free number to avoid A2P 10DLC (Express + Prisma/Postgres)",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "start": "npx prisma migrate deploy && node src/server.js",
    "dev": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "twilio": "^5.4.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "prisma@6.19.3": true
  }
}
